        // Negative Binomial Regression Demo
        function updateNBRegDemo() {
            const alpha = parseFloat(document.getElementById('alpha-slider').value);
            document.getElementById('alpha-value').textContent = alpha.toFixed(1);
            
            // Generate negative binomial distribution
            const mu = 5;
            const p = 1 / (1 + alpha * mu);
            const r = 1 / alpha;
            
            const x = Array.from({length: 21}, (_, i) => i);
            const y = x.map(k => {
                // Negative binomial PMF approximation
                const coef = Math.exp(logGamma(k + r) - logGamma(k + 1) - logGamma(r));
                return coef * Math.pow(p, r) * Math.pow(1 - p, k);
            });
            
            const trace1 = {
                x: x,
                y: y,
                type: 'bar',
                marker: { color: '#2563eb' },
                name: '负二项分布 (α=' + alpha + ')'
            };
            
            // Poisson for comparison
            const poissonY = x.map(k => (Math.pow(mu, k) * Math.exp(-mu)) / factorial(k));
            const trace2 = {
                x: x,
                y: poissonY,
                type: 'scatter',
                mode: 'lines+markers',
                line: { color: '#ef4444', dash: 'dash' },
                name: '泊松分布 (μ=5)'
            };
            
            const layout = {
                title: '负二项分布 vs 泊松分布 (α=' + alpha + ')',
                xaxis: { title: '处罚用时 (年)' },
                yaxis: { title: '概率' },
                annotations: [{
                    x: 0.5,
                    y: 1.15,
                    xref: 'paper',
                    yref: 'paper',
                    text: '方差 = μ + ' + alpha + 'μ² = ' + (mu + alpha * mu * mu).toFixed(2),
                    showarrow: false,
                    font: { size: 14, color: '#059669' }
                }],
                paper_bgcolor: "rgba(0,0,0,0)",
                plot_bgcolor: "rgba(0,0,0,0)"
            };
            
            Plotly.newPlot('nbreg-demo-chart', [trace1, trace2], layout, { responsive: true });
        }
        
        // Helper functions
        function logGamma(n) {
            // Lanczos approximation for log gamma
            const g = 7;
            const p = [0.99999999999980993, 676.5203681218851, -1259.1392167224028, 771.32342877765313, -176.61502916214059, 12.507343278686905, -0.13857109526572012, 9.9843695780195716e-6, 1.5056327351493116e-7];
            if (n < 0.5) return Math.log(Math.PI) - Math.log(Math.sin(Math.PI * n)) - logGamma(1 - n);
            n -= 1;
            let x = p[0];
            for (let i = 1; i < g + 2; i++) x += p[i] / (n + i);
            const t = n + g + 0.5;
            return 0.5 * Math.log(2 * Math.PI) + (n + 0.5) * Math.log(t) - t + Math.log(x);
        }
        
        function factorial(n) {
            if (n === 0) return 1;
            let result = 1;
            for (let i = 2; i <= n; i++) {
                result *= i;
            }
            return result;
        }
        
